generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  password       String
  name           String
  role           String   @default("VIEWER")
  roleId         String?
  isActive       Boolean  @default(true)
  lastLogin      DateTime?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id])
  userRole        Role?            @relation(fields: [roleId], references: [id])
  assignedAssets  Asset[]          @relation("AssignedUser")
  maintenanceLogs MaintenanceLog[] @relation("Technician")
  documents       Document[]
  importJobs      ImportJob[]
  auditLogs       AuditLog[]
  createdAssetTypes  AssetType[]  @relation("AssetTypeCreator")
  reviewedAssetTypes AssetType[]  @relation("AssetTypeReviewer")
  quantityAuditLogs QuantityAuditLog[]
  createdReports     UnitReport[]         @relation("ReportCreator")
  approvedReports    UnitReport[]         @relation("ReportApprover")
  reportNotifications ReportNotification[]
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  logo      String?
  address   String?
  settings  String   @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  branches           Branch[]
  assets             Asset[]
  suppliers          Supplier[]
  brands             Brand[]
  assetTypes         AssetType[]
  maintenanceLogs    MaintenanceLog[]
  importJobs         ImportJob[]
  mappingFeedbacks   MappingFeedback[]
  orgMappingPatterns OrgMappingPattern[]
}

model Branch {
  id             String   @id @default(uuid())
  name           String
  location       String?
  address        String?
  city           String?
  pincode        String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id])
  assets           Asset[]
  inventoryRecords InventoryRecord[]
  unitReports      UnitReport[]      @relation("UnitReports")
}

model Brand {
  id             String   @id @default(uuid())
  name           String
  nameLower      String   @default("")
  logo           String?
  website        String?
  description    String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  assets       Asset[]
  assetTypes   AssetType[]

  @@unique([organizationId, nameLower])
}

model Supplier {
  id               String   @id @default(uuid())
  companyName      String
  companyNameLower String   @default("")
  contactPerson    String?
  email            String?
  phone            String?
  address          String?
  city             String?
  pincode          String?
  website          String?
  organizationId   String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  assets       Asset[]

  @@unique([organizationId, companyNameLower])
}

model AssetType {
  id                     String    @id @default(uuid())
  name                   String
  description            String?
  depreciationMethod     String    @default("STRAIGHT_LINE")
  usefulLifeYears        Int       @default(5)
  salvageValuePercent    Float     @default(10)
  annualDepreciationRate Float?
  codePrefix             String?
  status                 String    @default("approved")
  rejectionReason        String?
  createdById            String?
  reviewedById           String?
  reviewedAt             DateTime?
  organizationId         String
  brandId                String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  brand        Brand?       @relation(fields: [brandId], references: [id])
  createdBy    User?        @relation("AssetTypeCreator", fields: [createdById], references: [id])
  reviewedBy   User?        @relation("AssetTypeReviewer", fields: [reviewedById], references: [id])
  assets       Asset[]
}

model Asset {
  id                 String   @id @default(uuid())
  assetCode          String   @unique
  name               String
  description        String?
  serialNumber       String?
  status             String   @default("ACTIVE")
  purchaseDate       DateTime?
  purchasePrice      Float    @default(0)
  currentValue       Float    @default(0)
  warrantyExpiryDate DateTime?
  location           String?
  branchId           String?
  brandId            String?
  supplierId         String?
  assetTypeId        String?
  organizationId     String
  assignedToUserId   String?
  photoUrl           String?
  userManualUrl      String?
  qrCode             String?
  tags               String   @default("[]")
  companyPolicyNotes String?
  quantity           Int      @default(1)
  minStockLevel      Int      @default(0)
  maxStockLevel      Int      @default(100)
  unit               String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  branch               Branch?               @relation(fields: [branchId], references: [id])
  brand                Brand?                @relation(fields: [brandId], references: [id])
  supplier             Supplier?             @relation(fields: [supplierId], references: [id])
  assetType            AssetType?            @relation(fields: [assetTypeId], references: [id])
  organization         Organization          @relation(fields: [organizationId], references: [id])
  assignedTo           User?                 @relation("AssignedUser", fields: [assignedToUserId], references: [id])
  depreciationSchedule DepreciationSchedule[]
  maintenanceLogs      MaintenanceLog[]
  inventoryRecords     InventoryRecord[]
  documents            Document[]
  qrCodeRecord         QRCode?
  quantityAuditLogs    QuantityAuditLog[]

  // Domain Extensions (1:1 optional)
  investmentExt        InvestmentExtension?
  physicalAssetExt     PhysicalAssetExtension?
  infrastructureExt    InfrastructureExtension?
  fixedAssetExt        FixedAssetExtension?
  itAssetExt           ITAssetExtension?
  digitalAssetExt      DigitalAssetExtension?
  realEstateExt        RealEstateExtension?
  governmentExt        GovernmentExtension?
  wealthExt            WealthExtension?
  naturalResourceExt   NaturalResourceExtension?
}

model InventoryRecord {
  id            String   @id @default(uuid())
  assetId       String
  branchId      String
  minStockLevel Int      @default(0)
  maxStockLevel Int      @default(100)
  lastAuditDate DateTime?
  auditedBy     String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  asset  Asset  @relation(fields: [assetId], references: [id])
  branch Branch @relation(fields: [branchId], references: [id])
}

model QuantityAuditLog {
  id               String   @id @default(uuid())
  assetId          String
  changedByUserId  String
  previousQuantity Int
  newQuantity      Int
  changedAt        DateTime @default(now())

  asset     Asset @relation(fields: [assetId], references: [id])
  changedBy User  @relation(fields: [changedByUserId], references: [id])
}

model DepreciationSchedule {
  id                     String   @id @default(uuid())
  assetId                String
  year                   Int
  month                  Int
  openingValue           Float
  depreciationAmount     Float
  closingValue           Float
  cumulativeDepreciation Float
  method                 String
  rate                   Float
  createdAt              DateTime @default(now())

  asset Asset @relation(fields: [assetId], references: [id])
}

model MaintenanceLog {
  id                  String   @id @default(uuid())
  assetId             String
  type                String   @default("PREVENTIVE")
  scheduledDate       DateTime
  completedDate       DateTime?
  cost                Float    @default(0)
  technicianId        String?
  description         String?
  status              String   @default("PENDING")
  nextMaintenanceDate DateTime?
  organizationId      String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  asset        Asset        @relation(fields: [assetId], references: [id])
  technician   User?        @relation("Technician", fields: [technicianId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
}

model Document {
  id         String   @id @default(uuid())
  assetId    String
  type       String   @default("OTHER")
  fileName   String
  fileUrl    String
  fileSize   Int      @default(0)
  mimeType   String?
  uploadedBy String?
  createdAt  DateTime @default(now())

  asset Asset @relation(fields: [assetId], references: [id])
  user  User? @relation(fields: [uploadedBy], references: [id])
}

model ImportJob {
  id                    String   @id @default(uuid())
  fileName              String
  status                String   @default("PENDING")
  totalRows             Int      @default(0)
  processedRows         Int      @default(0)
  errorRows             Int      @default(0)
  errorLog              String   @default("[]")
  importedBy            String
  organizationId        String
  mappingConfidenceAvg  Float?
  mappingRequiredManual Boolean  @default(false)
  createdAt             DateTime @default(now())
  completedAt           DateTime?

  user         User         @relation(fields: [importedBy], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  oldValue  String?
  newValue  String?
  ipAddress String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model MappingFeedback {
  id                    String   @id @default(uuid())
  organizationId        String
  excelHeaderOriginal   String
  excelHeaderNormalized String
  mappedSystemField     String
  wasCorrect            Boolean
  confidenceScore       Float?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, excelHeaderNormalized])
  @@index([mappedSystemField])
}

model OrgMappingPattern {
  id                    String   @id @default(uuid())
  organizationId        String
  excelHeaderNormalized String
  systemField           String
  usageCount            Int      @default(1)
  successRate           Float    @default(1.0)
  lastUsedAt            DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, excelHeaderNormalized, systemField])
  @@index([organizationId])
}

model QRCode {
  id            String    @id @default(uuid())
  assetId       String    @unique
  qrData        String
  status        String    @default("DRAFT")
  generatedAt   DateTime  @default(now())
  submittedAt   DateTime?
  approvedAt    DateTime?
  printedAt     DateTime?
  appliedAt     DateTime?
  updatedAt     DateTime  @updatedAt

  asset         Asset     @relation(fields: [assetId], references: [id])
}

model UnitReport {
  id              String    @id @default(uuid())
  unitId          String
  createdById     String
  status          String    @default("draft")
  approverId      String?
  signatureImage  String?
  rejectionReason String?
  createdAt       DateTime  @default(now())
  sentAt          DateTime?
  approvedAt      DateTime?
  rejectedAt      DateTime?

  unit        Branch  @relation("UnitReports", fields: [unitId], references: [id])
  createdBy   User    @relation("ReportCreator", fields: [createdById], references: [id])
  approver    User?   @relation("ReportApprover", fields: [approverId], references: [id])
  notifications ReportNotification[]
}

model ReportNotification {
  id         String   @id @default(uuid())
  reportId   String
  userId     String
  type       String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  report UnitReport @relation(fields: [reportId], references: [id])
  user   User       @relation(fields: [userId], references: [id])
}

model InventoryCategory {
  id              String   @id @default(uuid())
  name            String
  description     String?
  organizationId  String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items           InventoryItem[]
}

model InventoryItem {
  id              String   @id @default(uuid())
  name            String
  sku             String?
  categoryId      String?
  branchId        String?
  quantity        Int      @default(0)
  minStockLevel   Int      @default(0)
  maxStockLevel   Int      @default(100)
  unitPrice       Float    @default(0)
  totalValue      Float    @default(0)
  lastAuditDate   DateTime?
  auditedBy       String?
  notes           String?
  organizationId  String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  category        InventoryCategory? @relation(fields: [categoryId], references: [id])
  transactions    InventoryTransaction[]
}

model InventoryTransaction {
  id              String   @id @default(uuid())
  inventoryItemId String
  type            String
  quantity        Int
  previousQty     Int
  newQty          Int
  reason          String?
  performedBy     String?
  createdAt       DateTime @default(now())

  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]
  users       User[]
}

model RolePermission {
  id         String @id @default(uuid())
  roleId     String
  permission String

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permission])
}

// ─── DOMAIN EXTENSION MODELS ───────────────────────────────────────────

// 1. Investment Management
model InvestmentExtension {
  id              String   @id @default(uuid())
  assetId         String   @unique
  assetClass      String?  // EQUITY, DEBT, MUTUAL_FUND, CASH, HEDGE_FUND
  tickerSymbol    String?
  exchange        String?  // NSE, BSE, NASDAQ
  marketValue     Float    @default(0)
  purchaseNAV     Float    @default(0)
  currentNAV      Float    @default(0)
  unitsHeld       Float    @default(0)
  realizedGain    Float    @default(0)
  unrealizedGain  Float    @default(0)
  dividendYTD     Float    @default(0)
  couponRate      Float?
  maturityDate    DateTime?
  riskScore       Int?     // 1-10
  volatilityIndex Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

// 2. Physical Asset Management (Enhanced)
model PhysicalAssetExtension {
  id                  String   @id @default(uuid())
  assetId             String   @unique
  lifecycleStage      String   @default("ACTIVE") // PROCUREMENT, COMMISSIONING, ACTIVE, RETIRED
  mtbfHours           Float?   // Mean Time Between Failures
  mttrHours           Float?   // Mean Time To Repair
  oeeScore            Float?   // Overall Equipment Effectiveness 0-100
  totalOperatingHours Float    @default(0)
  lastFailureDate     DateTime?
  failureMode         String?  // FMEA failure mode
  failureCount        Int      @default(0)
  warrantyClaimStatus String?  // NONE, FILED, APPROVED, REJECTED
  warrantyClaimRef    String?
  spareParts          String   @default("[]") // JSON array of linked InventoryItem IDs
  conditionScore      Float?   // AI-computed 0-100
  nextPMDate          DateTime? // Predictive maintenance
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

// 3. Infrastructure Management
model InfrastructureExtension {
  id                   String   @id @default(uuid())
  assetId              String   @unique
  conditionIndex       Float?   // 0-100 civil engineering scale
  inspectionFrequency  String?  // MONTHLY, QUARTERLY, ANNUAL, BIENNIAL
  lastInspectionDate   DateTime?
  nextInspectionDate   DateTime?
  residualLifeYears    Float?
  latitude             Float?
  longitude            Float?
  complianceStatus     String   @default("COMPLIANT") // COMPLIANT, NON_COMPLIANT, PENDING
  complianceChecklist  String   @default("[]") // JSON array of regulation items
  failureSeverity      String?  // LOW, MEDIUM, HIGH, CRITICAL
  trafficVolume        Int?     // daily usage count
  deteriorationModel   String?  // MARKOV, LINEAR
  riskIndex            Float?   // ML-computed
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

// 4. Fixed Asset / Accounting
model FixedAssetExtension {
  id                 String   @id @default(uuid())
  assetId            String   @unique
  accountingBlock    String?  // Companies Act 2013 block category
  financialYear      String?  // e.g. "2025-26"
  wdvOpeningBalance  Float    @default(0)
  additionsThisYear  Float    @default(0)
  disposalsThisYear  Float    @default(0)
  wdvClosingBalance  Float    @default(0)
  impairmentFlag     Boolean  @default(false)
  impairmentAmount   Float    @default(0)
  revaluationReserve Float    @default(0)
  recoverableAmount  Float?
  auditFormRef       String?  // Statutory audit form reference
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

// 5. IT Asset Management (HAM/SAM/CAM)
model ITAssetExtension {
  id               String    @id @default(uuid())
  assetId          String    @unique
  subType          String    @default("HAM") // HAM, SAM, CAM
  // HAM fields
  cpuModel         String?
  ramGB            Int?
  storageGB        Int?
  storageType      String?   // SSD, HDD, NVMe
  osVersion        String?
  eolDate          DateTime? // End of Life
  // SAM fields
  licenseKey       String?
  licenseType      String?   // PERPETUAL, SUBSCRIPTION, OPEN_SOURCE
  licensedSeats    Int?
  allocatedSeats   Int?
  licenseVendor    String?
  licenseExpiry    DateTime?
  costPerSeat      Float?
  // CAM fields
  cloudProvider    String?   // AWS, AZURE, GCP
  cloudResourceId  String?
  instanceType     String?
  region           String?
  monthlyCost      Float?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

// 6. Digital Asset Management
model DigitalAssetExtension {
  id              String    @id @default(uuid())
  assetId         String    @unique
  mediaType       String?   // IMAGE, VIDEO, PDF, SPREADSHEET, CAD, OTHER
  keywords        String    @default("[]") // JSON array
  projectName     String?
  campaignName    String?
  usageRights     String?   // ROYALTY_FREE, LICENSED, PROPRIETARY
  rightsExpiry     DateTime?
  versionNumber   String    @default("1.0")
  downloadCount   Int       @default(0)
  fileHash        String?   // perceptual hash for duplicate detection
  collectionName  String?
  lastAccessedAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

// 7. Real Estate Management
model RealEstateExtension {
  id                  String    @id @default(uuid())
  assetId             String    @unique
  propertyType        String?   // RESIDENTIAL, COMMERCIAL, INDUSTRIAL, LAND
  carpetAreaSqft      Float?
  builtUpAreaSqft     Float?
  tenantName          String?
  leaseStart          DateTime?
  leaseEnd            DateTime?
  monthlyRent         Float     @default(0)
  rentReceived        Float     @default(0)
  escalationPercent   Float?
  stampDutyValue      Float?
  marketValueEstimate Float?
  rentalYield         Float?    // computed
  occupancyStatus     String    @default("VACANT") // OCCUPIED, VACANT, UNDER_RENOVATION
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

// 8. Government / Public Asset Management
model GovernmentExtension {
  id                  String    @id @default(uuid())
  assetId             String    @unique
  custodianDept       String?
  gfrClassification   String?   // MOVABLE, IMMOVABLE per GFR 2017
  tenderRefNumber     String?
  gemPortalId         String?
  procurementMode     String?   // GEM, OPEN_TENDER, LIMITED_TENDER, SINGLE_SOURCE
  disposalMethod      String?   // AUCTION, WRITE_OFF, TRANSFER
  auctionDate         DateTime?
  auctionReservePrice Float?
  interDeptTransferTo String?
  transferDate        DateTime?
  publicRegister      Boolean   @default(false) // publicly viewable
  utilizationScore    Float?    // AI-computed
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

// 9. Wealth Management
model WealthExtension {
  id                String   @id @default(uuid())
  assetId           String   @unique
  clientName        String?
  clientRiskAppetite String? // CONSERVATIVE, MODERATE, AGGRESSIVE
  investmentHorizon  String? // SHORT, MEDIUM, LONG
  targetAllocation   String  @default("{}") // JSON: { equity: 60, debt: 30, gold: 10 }
  actualAllocation   String  @default("{}") // JSON
  taxBracket         String? // e.g. "30%"
  capitalGainsTax    Float   @default(0)
  rentalIncomeTax    Float   @default(0)
  depreciationBenefit Float  @default(0)
  successionNotes    String?
  documentVaultUrl   String?
  financialGoal      String? // RETIREMENT, EDUCATION, CORPUS
  goalTargetAmount   Float?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

// 10. Natural Resource Management
model NaturalResourceExtension {
  id                      String    @id @default(uuid())
  assetId                 String    @unique
  resourceType            String?   // FOREST, WATERSHED, AGRICULTURAL, MARINE, CARBON_CREDITS
  carbonCredits           Float     @default(0)
  registryId              String?   // voluntary carbon market registry
  vintageYear             Int?
  creditPricePerTon       Float?
  ecosystemService        String?   // CARBON_SEQUESTRATION, WATER_YIELD, BIODIVERSITY
  ecosystemValuation      Float?
  complianceClearance     String?   // PCB, FOREST_CLEARANCE, etc.
  clearanceExpiry         DateTime?
  degradationIndex        Float?    // 0-100
  lastFieldSurveyDate     DateTime?
  nextAssessmentDate      DateTime?
  ndviScore               Float?    // Normalized Difference Vegetation Index
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
}
